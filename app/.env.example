# Environment variables for the Flask application
# Copy this file to .env and update with your actual values

# Database Configuration for Fabric SQL Database
# Server format for TRANSACTIONAL ENDPOINT: workspace-id.database.fabric.microsoft.com
# DO NOT use .datawarehouse.fabric.microsoft.com (that's the analytics endpoint)
DB_SERVER=your-workspace-id.database.fabric.microsoft.com
DB_NAME=your-database-name

# ODBC Driver (use whichever you have installed)
DB_DRIVER={ODBC Driver 17 for SQL Server}
# DB_DRIVER={ODBC Driver 18 for SQL Server}

# Authentication Method
# Set to True for Entra ID (Azure AD) authentication (recommended for Fabric SQL)
# Set to False to use SQL authentication (requires DB_USERNAME and DB_PASSWORD)
USE_ENTRA_AUTH=True

# Only needed if USE_ENTRA_AUTH=False (not recommended for Fabric SQL)
# DB_USERNAME=your-username
# DB_PASSWORD=your-password

# Application Configuration
FLASK_ENV=development
FLASK_DEBUG=True
